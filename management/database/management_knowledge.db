-- 中层管理者知识库数据库
-- Database: management_knowledge.db

-- =====================================================
-- 1. 知识分类表
-- =====================================================
CREATE TABLE IF NOT EXISTS knowledge_categories (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,           -- 分类名称
    parent_id INTEGER DEFAULT 0,          -- 父分类ID（0为顶级）
    description TEXT,                    -- 分类描述
    icon TEXT,                           -- 图标
    sort_order INTEGER DEFAULT 0,         -- 排序
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (parent_id) REFERENCES knowledge_categories(id)
);

-- =====================================================
-- 2. 知识点表
-- =====================================================
CREATE TABLE IF NOT EXISTS knowledge_points (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    category_id INTEGER NOT NULL,
    title TEXT NOT NULL,                 -- 知识点标题
    content TEXT,                        -- 核心内容
    key_takeaways TEXT,                  -- 关键要点（JSON数组）
    examples TEXT,                       -- 案例示例（JSON数组）
    tags TEXT,                           -- 标签（逗号分隔）
    importance INTEGER DEFAULT 3,         -- 重要程度（1-5）
    difficulty INTEGER DEFAULT 2,         -- 难度（1-5）
    read_count INTEGER DEFAULT 0,        -- 阅读次数
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (category_id) REFERENCES knowledge_categories(id)
);

-- =====================================================
-- 3. 管理模型表
-- =====================================================
CREATE TABLE IF NOT EXISTS management_models (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,           -- 模型名称
    category TEXT NOT NULL,              -- 分类
    description TEXT,                     -- 模型描述
    formula TEXT,                        -- 公式/框架
    application_scenario TEXT,           -- 应用场景
    steps TEXT,                          -- 使用步骤（JSON数组）
    examples TEXT,                        -- 使用案例
    limitations TEXT,                    -- 局限性
    resources TEXT,                      -- 参考资源
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 4. 工具模板表
-- =====================================================
CREATE TABLE IF NOT EXISTS templates (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,                   -- 模板名称
    type TEXT NOT NULL,                   -- 类型（report/checklist/sOP）
    category TEXT,                        -- 分类
    description TEXT,                     -- 描述
    content_template TEXT,               -- 模板内容
    fields TEXT,                          -- 字段说明（JSON）
    usage_guide TEXT,                     -- 使用指南
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 5. 案例库表
-- =====================================================
CREATE TABLE IF NOT EXISTS cases (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL,                  -- 案例标题
    category TEXT NOT NULL,               -- 分类
    problem TEXT,                         -- 问题描述
    analysis TEXT,                        -- 分析过程
    solution TEXT,                        -- 解决方案
    result TEXT,                          -- 最终结果
    lessons TEXT,                         -- 经验教训
    tags TEXT,                            -- 标签
    views INTEGER DEFAULT 0,              -- 浏览次数
    rating INTEGER DEFAULT 0,             -- 评分
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 6. 常见问题表
-- =====================================================
CREATE TABLE IF NOT EXISTS faqs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    question TEXT NOT NULL,               -- 问题
    answer TEXT NOT NULL,                 -- 答案
    category TEXT NOT NULL,               -- 分类
    keywords TEXT,                        -- 关键词
    views INTEGER DEFAULT 0,              -- 询问次数
    useful_count INTEGER DEFAULT 0,      -- 有用次数
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 7. 学习进度表
-- =====================================================
CREATE TABLE IF NOT EXISTS learning_progress (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id TEXT NOT NULL,               -- 用户标识
    item_type TEXT NOT NULL,              -- 类型（knowledge/model/case）
    item_id INTEGER NOT NULL,            -- 内容ID
    status TEXT DEFAULT 'not_started',    -- 状态
    progress_percent INTEGER DEFAULT 0, -- 进度
    notes TEXT,                          -- 学习笔记
    last_accessed TIMESTAMP,             -- 最后访问
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(user_id, item_type, item_id)
);

-- =====================================================
-- 8. 收藏夹表
-- =====================================================
CREATE TABLE IF NOT EXISTS favorites (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id TEXT NOT NULL,
    item_type TEXT NOT NULL,
    item_id INTEGER NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(user_id, item_type, item_id)
);

-- =====================================================
-- 9. 技能清单表
-- =====================================================
CREATE TABLE IF NOT EXISTS skills (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE,
    category TEXT NOT NULL,
    description TEXT,
    level_required INTEGER,              -- 所需级别
    sub_skills TEXT,                      -- 子技能（JSON数组）
    related_resources TEXT,             -- 相关资源
    practice_methods TEXT,              -- 练习方法
    assessment_criteria TEXT,            -- 评估标准
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 10. 行动清单表
-- =====================================================
CREATE TABLE IF NOT EXISTS action_items (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id TEXT NOT NULL,
    title TEXT NOT NULL,
    description TEXT,
    category TEXT,
    priority INTEGER DEFAULT 3,           -- 优先级 1-5
    due_date DATE,
    status TEXT DEFAULT 'pending',       -- pending/in_progress/done
    completed_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =====================================================
-- 索引
-- =====================================================
CREATE INDEX IF NOT EXISTS idx_knowledge_category ON knowledge_points(category_id);
CREATE INDEX IF NOT EXISTS idx_knowledge_tags ON knowledge_points(tags);
CREATE INDEX IF NOT EXISTS idx_cases_category ON cases(category_id);
CREATE INDEX IF NOT EXISTS idx_faqs_category ON faqs(category_id);
CREATE INDEX IF NOT EXISTS idx_progress_user ON learning_progress(user_id);
CREATE INDEX IF NOT EXISTS idx_actions_user_status ON action_items(user_id, status);

